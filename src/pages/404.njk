{% extends "layouts/base.njk" %}

{% set title = "Страница не найдена — 404" %}
{% set description = "Запрашиваемая страница не найдена" %}

{% block content %}
<section class="error-404 py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-md-8 col-lg-6 text-center">
                <h1 class="display-1 fw-bold text-primary">404</h1>
                <h2 class="h3 mb-4">Страница не найдена</h2>
                <p class="lead mb-4">
                    К сожалению, страница, которую вы ищете, не существует или была перемещена.
                </p>
                <div class="d-flex gap-3 justify-content-center flex-wrap">
                    <a href="/" class="btn btn-primary">
                        <svg class="sprite-icon me-2">
                            <use xlink:href="/__spritemap#sprite-geo"></use>
                        </svg>
                        На главную
                    </a>
                    <a href="javascript:history.back()" class="btn btn-secondary">
                        Назад
                    </a>
                </div>
                
                {# Хлебные крошки #}
                <nav aria-label="breadcrumb" class="mt-5">
                    <ol class="breadcrumb justify-content-center">
                        <li class="breadcrumb-item">
                            <a href="/">Главная</a>
                        </li>
                        <li class="breadcrumb-item active" aria-current="page">404</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</section>

{# JSON-LD BreadcrumbList #}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {
            "@type": "ListItem",
            "position": 1,
            "name": "Главная",
            "item": "{{ site.config.base_url }}/"
        },
        {
            "@type": "ListItem",
            "position": 2,
            "name": "404",
            "item": "{{ site.config.base_url }}/404/"
        }
    ]
}
</script>
{% endblock %}
