{% extends "layouts/base.njk" %}

{% set title = "Контакты — Мой сайт" %}
{% set description = "Контактная информация: телефон, email, адрес. Свяжитесь с нами любым удобным способом." %}

{% block content %}
<section class="contacts py-5">
    <div class="container">
        <h1 class="mb-4">Контакты</h1>
        <p class="lead mb-5">Свяжитесь с нами любым удобным способом</p>
        
        <div class="row g-4">
            <!-- Контактная информация -->
            <div class="col-12 col-lg-6">
                <div class="card h-100">
                    <div class="card-body">
                        <h2 class="h4 card-title mb-4">Контактная информация</h2>
                        
                        <div class="vstack gap-3">
                            <div class="d-flex align-items-center gap-3">
                                <svg class="sprite-icon text-primary" width="24" height="24">
                                    <use xlink:href="/__spritemap#sprite-geo"></use>
                                </svg>
                                <div>
                                    <strong>Адрес:</strong><br>
                                    {{ site.contacts.address }}
                                </div>
                            </div>
                            
                            <div class="d-flex align-items-center gap-3">
                                <svg class="sprite-icon text-primary" width="24" height="24">
                                    <use xlink:href="/__spritemap#sprite-burger"></use>
                                </svg>
                                <div>
                                    <strong>Телефон:</strong><br>
                                    <a href="tel:{{ site.contacts.phone_link }}">{{ site.contacts.phone_display }}</a>
                                </div>
                            </div>
                            
                            <div class="d-flex align-items-center gap-3">
                                <svg class="sprite-icon text-primary" width="24" height="24">
                                    <use xlink:href="/__spritemap#sprite-vite"></use>
                                </svg>
                                <div>
                                    <strong>Email:</strong><br>
                                    <a href="mailto:{{ site.contacts.email }}">{{ site.contacts.email }}</a>
                                </div>
                            </div>
                            
                            <div class="d-flex align-items-center gap-3">
                                <svg class="sprite-icon text-primary" width="24" height="24">
                                    <use xlink:href="/__spritemap#sprite-javascript"></use>
                                </svg>
                                <div>
                                    <strong>Режим работы:</strong><br>
                                    {{ site.contacts.working_hours }}
                                </div>
                            </div>
                        </div>
                        
                        <!-- Соцсети -->
                        <div class="mt-4">
                            <h3 class="h6 mb-3">Мы в социальных сетях:</h3>
                            <div class="d-flex gap-3">
                                {% if site.social.vk %}
                                <a href="{{ site.social.vk }}" target="_blank" rel="noopener" class="btn btn-outline-primary">
                                    VK
                                </a>
                                {% endif %}
                                {% if site.social.telegram %}
                                <a href="{{ site.social.telegram }}" target="_blank" rel="noopener" class="btn btn-outline-info">
                                    Telegram
                                </a>
                                {% endif %}
                                {% if site.social.whatsapp %}
                                <a href="{{ site.social.whatsapp }}" target="_blank" rel="noopener" class="btn btn-outline-success">
                                    WhatsApp
                                </a>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Форма обратной связи -->
            <div class="col-12 col-lg-6">
                <div class="card h-100">
                    <div class="card-body">
                        <h2 class="h4 card-title mb-4">Напишите нам</h2>
                        
                        <form action="/thank-you/" method="POST" class="vstack gap-3">
                            <div>
                                <label for="name" class="form-label">Ваше имя</label>
                                <input type="text" class="form-control" id="name" name="name" required>
                            </div>
                            
                            <div>
                                <label for="email" class="form-label">Email</label>
                                <input type="email" class="form-control" id="email" name="email" required>
                            </div>
                            
                            <div>
                                <label for="phone" class="form-label">Телефон</label>
                                <input type="tel" class="form-control" id="phone" name="phone">
                            </div>
                            
                            <div>
                                <label for="message" class="form-label">Сообщение</label>
                                <textarea class="form-control" id="message" name="message" rows="4" required></textarea>
                            </div>
                            
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" id="privacy" required checked>
                                <label class="form-check-label" for="privacy">
                                    Согласен на <a href="/privacy/">обработку персональных данных</a>
                                </label>
                            </div>
                            
                            <button type="submit" class="btn btn-primary">Отправить</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Хлебные крошки -->
        <nav aria-label="breadcrumb" class="mt-5">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Главная</a></li>
                <li class="breadcrumb-item active" aria-current="page">Контакты</li>
            </ol>
        </nav>
    </div>
</section>

{# JSON-LD ContactPage #}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "name": "Контакты",
    "description": "{{ site.seo.description }}",
    "url": "{{ site.config.base_url }}/contacts/"
}
</script>
{% endblock %}
