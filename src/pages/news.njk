                        <div class="text-muted small mb-2">
                            <time datetime="2026-03-15">15 марта 2026</time>
                        </div>
                        <h2 class="h5 card-title">
                            <a href="/news/article-1/" class="text-decoration-none">Заголовок новости 1</a>
